        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Architecture Patterns\",\n  \"author\": \"Mark Richards\",\n  \"isbn\": \"978-1492052203\",\n  \"price\": 38.00,\n  \"stock\": 5\n}"
