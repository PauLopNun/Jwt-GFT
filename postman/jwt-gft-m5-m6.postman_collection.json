    {
      "name": "06 POST books without token (unauthorized)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Domain-Driven Design\",\n  \"author\": \"Eric Evans\",\n  \"isbn\": \"978-0321125217\",\n  \"price\": 42.50,\n  \"stock\": 4\n}"
        },
        "url": "{{baseUrl}}/api/books"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('401 Unauthorized', function () { pm.response.to.have.status(401); });"
